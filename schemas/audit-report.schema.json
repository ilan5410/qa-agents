{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/audit-report.schema.json",
  "title": "Audit Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_status",
    "original_unchanged",
    "all_edits_tracked",
    "silent_xml_changes_detected",
    "reject_all_simulation",
    "issue_log_reconciliation",
    "changed_parts",
    "warnings",
    "failures",
    "recommendations"
  ],
  "properties": {
    "audit_status": {
      "type": "string",
      "enum": ["PASS", "WARN", "FAIL"]
    },
    "original_unchanged": { "$ref": "#/$defs/check" },
    "all_edits_tracked": { "$ref": "#/$defs/check" },
    "silent_xml_changes_detected": { "$ref": "#/$defs/check" },
    "reject_all_simulation": { "$ref": "#/$defs/check" },
    "issue_log_reconciliation": { "$ref": "#/$defs/check" },
    "changed_parts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["part", "change_summary", "expected"],
        "properties": {
          "part": { "type": "string" },
          "change_summary": { "type": "string" },
          "expected": { "type": "boolean" }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "failures": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "details"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["PASS", "WARN", "FAIL", "NOT_RUN"]
        },
        "details": { "type": "string" }
      }
    }
  }
}
