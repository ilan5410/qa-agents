{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/issue-log.schema.json",
  "title": "Issue Log",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "document_id",
    "issues",
    "summary",
    "unresolved_high_priority",
    "generated_by",
    "timestamp"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "document_id": { "type": "string" },
    "issues": {
      "type": "array",
      "items": { "$ref": "issue.schema.json" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_issues", "by_severity", "by_edit_safety", "narrative"],
      "properties": {
        "total_issues": { "type": "integer", "minimum": 0 },
        "by_severity": { "$ref": "#/$defs/counts" },
        "by_edit_safety": { "$ref": "#/$defs/counts" },
        "narrative": { "type": "string" }
      }
    },
    "unresolved_high_priority": {
      "type": "array",
      "items": { "type": "string" }
    },
    "generated_by": { "type": "string" },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "counts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    }
  }
}
